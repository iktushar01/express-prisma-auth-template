model HrDesignation {
  id          String     @id @default(uuid())
  name        String
  basicSalary Decimal    @default(0) @db.Decimal(12, 2)
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]

  @@map("hr_designations")
}

model HrEarningHead {
  id        String            @id @default(uuid())
  name      String
  isDeleted Boolean           @default(false)
  deletedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  earnings  EmployeeEarning[]

  @@map("hr_earning_heads")
}

model HrDeductionHead {
  id          String              @id @default(uuid())
  name        String
  isDeleted   Boolean             @default(false)
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deductions  EmployeeDeduction[]

  @@map("hr_deduction_heads")
}

model Employee {
  id            String              @id @default(uuid())
  name          String
  contactNo     String              @default("")
  designationId String?
  designation   HrDesignation?      @relation(fields: [designationId], references: [id])
  status        EmployeeStatus      @default(ACTIVE)
  hasAccess     Boolean             @default(false)
  isDeleted     Boolean             @default(false)
  deletedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  earnings      EmployeeEarning[]
  deductions    EmployeeDeduction[]
  basicSalaries EmployeeBasicSalary[]
  salaryPayments SalaryPayment[]

  @@map("employees")
}

model EmployeeEarning {
  id         String        @id @default(uuid())
  employeeId String
  employee   Employee      @relation(fields: [employeeId], references: [id])
  headId     String
  head       HrEarningHead @relation(fields: [headId], references: [id])
  amount     Decimal       @db.Decimal(12, 2)
  date       DateTime
  note       String        @default("")
  isDeleted  Boolean       @default(false)
  deletedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([employeeId])
  @@map("employee_earnings")
}

model EmployeeDeduction {
  id         String          @id @default(uuid())
  employeeId String
  employee   Employee        @relation(fields: [employeeId], references: [id])
  headId     String
  head       HrDeductionHead @relation(fields: [headId], references: [id])
  amount     Decimal         @db.Decimal(12, 2)
  date       DateTime
  note       String          @default("")
  isDeleted  Boolean         @default(false)
  deletedAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([employeeId])
  @@map("employee_deductions")
}

model EmployeeBasicSalary {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  amount     Decimal  @db.Decimal(12, 2)
  date       DateTime
  note       String   @default("")
  isDeleted  Boolean  @default(false)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId])
  @@map("employee_basic_salaries")
}

model SalaryPayment {
  id            String   @id @default(uuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  amount        Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime
  paymentMethod String   @default("Cash")
  note          String   @default("")
  isDeleted     Boolean  @default(false)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([employeeId])
  @@map("salary_payments")
}
